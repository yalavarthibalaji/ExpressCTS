<?xml version="1.0" encoding="UTF-8"?>
<zk>

    <!-- When session times out, send user back to login -->
    <device-config>
        <device-type>ajax</device-type>
        <timeout-uri>/login/login.zul</timeout-uri>
    </device-config>

    <!-- Session config -->
    <session-config>
        <device-type>ajax</device-type>
        <max-desktops-per-session>10</max-desktops-per-session>
    </session-config>

</zk>