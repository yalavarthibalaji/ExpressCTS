<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="batchChequeReport"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="782"
              leftMargin="30"
              rightMargin="30"
              topMargin="20"
              bottomMargin="20">

    <!-- Parameters passed from ReportServiceImpl -->
    <parameter name="batchId"       class="java.lang.String"/>
    <parameter name="makerName"     class="java.lang.String"/>
    <parameter name="batchStatus"   class="java.lang.String"/>
    <parameter name="totalCheques"  class="java.lang.Integer"/>
    <parameter name="totalAmount"   class="java.math.BigDecimal"/>
    <parameter name="generatedAt"   class="java.lang.String"/>

    <!-- Fields — must match getter names in ChequeReportRow.java -->
    <field name="serialNo"      class="java.lang.Integer"/>
    <field name="chequeNo"      class="java.lang.String"/>
    <field name="accountNo"     class="java.lang.String"/>
    <field name="accountHolder" class="java.lang.String"/>
    <field name="payeeName"     class="java.lang.String"/>
    <field name="amount"        class="java.math.BigDecimal"/>
    <field name="chequeDate"    class="java.lang.String"/>
    <field name="micrCode"      class="java.lang.String"/>
    <field name="status"        class="java.lang.String"/>
    <field name="repairStatus"  class="java.lang.String"/>

    <!-- TITLE BAND -->
    <title>
        <band height="110">

            <staticText>
                <reportElement x="0" y="0" width="782" height="28"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="15" isBold="true"/>
                </textElement>
                <text><![CDATA[ExpressClear CTS — Batch Cheque Detail Report]]></text>
            </staticText>

            <!-- Batch ID -->
            <textField>
                <reportElement x="0" y="32" width="400" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Batch ID  :  " + $P{batchId}]]>
                </textFieldExpression>
            </textField>

            <!-- Status -->
            <textField>
                <reportElement x="0" y="52" width="400" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Status    :  " + $P{batchStatus}]]>
                </textFieldExpression>
            </textField>

            <!-- Maker -->
            <textField>
                <reportElement x="0" y="72" width="400" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Maker     :  " + $P{makerName}]]>
                </textFieldExpression>
            </textField>

            <!-- Total cheques (right side) -->
            <textField>
                <reportElement x="400" y="32" width="382" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Total Cheques : " + $P{totalCheques}]]>
                </textFieldExpression>
            </textField>

            <!-- Total amount (right side) -->
            <textField>
                <reportElement x="400" y="52" width="382" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Total Amount  : Rs. " + ($P{totalAmount} != null ? $P{totalAmount}.setScale(2, java.math.RoundingMode.HALF_UP).toPlainString() : "0.00")]]>
                </textFieldExpression>
            </textField>

            <!-- Generated at (right side) -->
            <textField>
                <reportElement x="400" y="72" width="382" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Generated : " + $P{generatedAt}]]>
                </textFieldExpression>
            </textField>

            <!-- Separator line -->
            <line>
                <reportElement x="0" y="100" width="782" height="1" forecolor="#2C3E50"/>
            </line>

        </band>
    </title>

    <!-- COLUMN HEADER BAND -->
    <columnHeader>
        <band height="28">

            <staticText>
                <reportElement x="0"   y="0" width="36"  height="28"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[#]]></text>
            </staticText>

            <staticText>
                <reportElement x="36"  y="0" width="80"  height="28"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Cheque No]]></text>
            </staticText>

            <staticText>
                <reportElement x="116" y="0" width="110" height="28"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Account No]]></text>
            </staticText>

            <staticText>
                <reportElement x="226" y="0" width="120" height="28"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Account Holder]]></text>
            </staticText>

            <staticText>
                <reportElement x="346" y="0" width="110" height="28"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Payee Name]]></text>
            </staticText>

            <staticText>
                <reportElement x="456" y="0" width="100" height="28"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Amount (Rs.)  ]]></text>
            </staticText>

            <staticText>
                <reportElement x="556" y="0" width="86"  height="28"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Cheque Date]]></text>
            </staticText>

            <staticText>
                <reportElement x="642" y="0" width="80"  height="28"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Status]]></text>
            </staticText>

            <staticText>
                <reportElement x="722" y="0" width="60"  height="28"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Repair]]></text>
            </staticText>

        </band>
    </columnHeader>

    <!-- DETAIL BAND — one row per cheque -->
    <detail>
        <band height="22">

            <textField>
                <reportElement x="0"   y="0" width="36"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{serialNo}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="36"  y="0" width="80"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{chequeNo}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="116" y="0" width="110" height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{accountNo}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="226" y="0" width="120" height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{accountHolder} != null ? $F{accountHolder} : "—"]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="346" y="0" width="110" height="22"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{payeeName} != null ? $F{payeeName} : "—"]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="456" y="0" width="100" height="22"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{amount} != null ? $F{amount}.setScale(2, java.math.RoundingMode.HALF_UP).toPlainString() : "0.00"]]>
                </textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="556" y="0" width="86"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{chequeDate} != null ? $F{chequeDate} : "—"]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="642" y="0" width="80"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{status} != null ? $F{status} : "—"]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="722" y="0" width="60"  height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{repairStatus} != null ? $F{repairStatus} : "—"]]></textFieldExpression>
            </textField>

            <!-- Row separator -->
            <line>
                <reportElement x="0" y="21" width="782" height="1" forecolor="#DDDDDD"/>
            </line>

        </band>
    </detail>

    <!-- PAGE FOOTER — must come before <summary> in JasperReports XSD -->
    <pageFooter>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="782" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Page " + $V{PAGE_NUMBER}]]>
                </textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- SUMMARY BAND — printed once after the last detail row, on the last page -->
    <summary>
        <band height="30">
            <line>
                <reportElement x="0" y="0" width="782" height="1" forecolor="#2C3E50"/>
            </line>
            <staticText>
                <reportElement x="0" y="4" width="456" height="22"
                               backcolor="#F0F4F8" mode="Opaque"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Amount :  ]]></text>
            </staticText>
            <textField>
                <reportElement x="456" y="4" width="100" height="22"
                               backcolor="#F0F4F8" mode="Opaque"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$P{totalAmount} != null ? $P{totalAmount}.setScale(2, java.math.RoundingMode.HALF_UP).toPlainString() : "0.00"]]>
                </textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>