<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="myBatchReport"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="782"
              leftMargin="30"
              rightMargin="30"
              topMargin="20"
              bottomMargin="20">

    <!-- Parameters passed from ReportServiceImpl -->
    <parameter name="reportTitle"  class="java.lang.String"/>
    <parameter name="makerName"    class="java.lang.String"/>
    <parameter name="fromDate"     class="java.lang.String"/>
    <parameter name="toDate"       class="java.lang.String"/>
    <parameter name="totalBatches" class="java.lang.Integer"/>

    <!-- Fields — must match getter names in BatchReportRow.java -->
    <field name="serialNo"       class="java.lang.Integer"/>
    <field name="batchId"        class="java.lang.String"/>
    <field name="chequeCount"    class="java.lang.Integer"/>
    <field name="expectedAmount" class="java.math.BigDecimal"/>
    <field name="actualAmount"   class="java.math.BigDecimal"/>
    <field name="status"         class="java.lang.String"/>
    <field name="createdAt"      class="java.lang.String"/>

    <!-- TITLE BAND — printed once at top -->
    <title>
        <band height="100">

            <staticText>
                <reportElement x="0" y="0" width="782" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[ExpressClear CTS — My Batches Report]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="35" width="400" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Maker : " + $P{makerName}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="55" width="400" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Date Range : " + $P{fromDate} + "  to  " + $P{toDate}]]>
                </textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="75" width="400" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Total Batches : " + $P{totalBatches}]]>
                </textFieldExpression>
            </textField>

        </band>
    </title>

    <!-- COLUMN HEADER BAND — forecolor goes on reportElement, NOT textElement -->
    <columnHeader>
        <band height="30">

            <!-- Sr No -->
            <staticText>
                <reportElement x="0" y="0" width="40" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Sr No]]></text>
            </staticText>

            <!-- Batch ID -->
            <staticText>
                <reportElement x="40" y="0" width="160" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Batch ID]]></text>
            </staticText>

            <!-- Cheque Count -->
            <staticText>
                <reportElement x="200" y="0" width="100" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Cheque Count]]></text>
            </staticText>

            <!-- Expected Amount -->
            <staticText>
                <reportElement x="300" y="0" width="130" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Expected Amount]]></text>
            </staticText>

            <!-- Actual Amount -->
            <staticText>
                <reportElement x="430" y="0" width="130" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Actual Amount]]></text>
            </staticText>

            <!-- Status -->
            <staticText>
                <reportElement x="560" y="0" width="120" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Status]]></text>
            </staticText>

            <!-- Created At -->
            <staticText>
                <reportElement x="680" y="0" width="102" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Created At]]></text>
            </staticText>

        </band>
    </columnHeader>

    <!-- DETAIL BAND — one row per batch -->
    <detail>
        <band height="25">

            <!-- Sr No -->
            <textField>
                <reportElement x="0" y="0" width="40" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{serialNo}]]>
                </textFieldExpression>
            </textField>

            <!-- Batch ID -->
            <textField>
                <reportElement x="40" y="0" width="160" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{batchId}]]>
                </textFieldExpression>
            </textField>

            <!-- Cheque Count -->
            <textField>
                <reportElement x="200" y="0" width="100" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{chequeCount}]]>
                </textFieldExpression>
            </textField>

            <!-- Expected Amount -->
            <textField>
                <reportElement x="300" y="0" width="130" height="25"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Rs. " + $F{expectedAmount}.setScale(2, java.math.RoundingMode.HALF_UP).toPlainString()]]>
                </textFieldExpression>
            </textField>

            <!-- Actual Amount -->
            <textField>
                <reportElement x="430" y="0" width="130" height="25"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Rs. " + $F{actualAmount}.setScale(2, java.math.RoundingMode.HALF_UP).toPlainString()]]>
                </textFieldExpression>
            </textField>

            <!-- Status -->
            <textField>
                <reportElement x="560" y="0" width="120" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{status}]]>
                </textFieldExpression>
            </textField>

            <!-- Created At -->
            <textField>
                <reportElement x="680" y="0" width="102" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{createdAt}]]>
                </textFieldExpression>
            </textField>

            <!-- Row separator line -->
            <line>
                <reportElement x="0" y="24" width="782" height="1"
                               forecolor="#CCCCCC"/>
            </line>

        </band>
    </detail>

    <!-- PAGE FOOTER -->
    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="782" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Page " + $V{PAGE_NUMBER}]]>
                </textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>