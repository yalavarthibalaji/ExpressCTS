<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="checkerBatchReport"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="782"
              leftMargin="30"
              rightMargin="30"
              topMargin="20"
              bottomMargin="20">

    <!-- Parameters passed from ReportsServiceImpl.generateCheckerBatchReport() -->
    <parameter name="reportTitle"  class="java.lang.String"/>
    <parameter name="checkerName"  class="java.lang.String"/>
    <parameter name="fromDate"     class="java.lang.String"/>
    <parameter name="toDate"       class="java.lang.String"/>
    <parameter name="totalBatches" class="java.lang.Integer"/>
    <parameter name="grandTotal"   class="java.math.BigDecimal"/>

    <!-- Fields — must match getter names in CheckerBatchReportRow.java -->
    <field name="serialNo"    class="java.lang.Integer"/>
    <field name="batchId"     class="java.lang.String"/>
    <field name="chequeCount" class="java.lang.Integer"/>
    <field name="makerName"   class="java.lang.String"/>
    <field name="actualAmount" class="java.math.BigDecimal"/>
    <field name="verifiedAt"  class="java.lang.String"/>
    <field name="status"      class="java.lang.String"/>

    <!-- TITLE BAND — printed once at the top of the report -->
    <title>
        <band height="110">

            <!-- Report heading -->
            <staticText>
                <reportElement x="0" y="0" width="782" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[ExpressClear CTS — Verified Batches Report]]></text>
            </staticText>

            <!-- Checker name -->
            <textField>
                <reportElement x="0" y="35" width="400" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Checker : " + $P{checkerName}]]>
                </textFieldExpression>
            </textField>

            <!-- Date range label -->
            <textField>
                <reportElement x="0" y="55" width="400" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Date Range : " + $P{fromDate} + "  to  " + $P{toDate}]]>
                </textFieldExpression>
            </textField>

            <!-- Total batches count -->
            <textField>
                <reportElement x="0" y="75" width="400" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Total Batches : " + $P{totalBatches}]]>
                </textFieldExpression>
            </textField>

            <!-- Grand total amount — shown top right -->
            <textField>
                <reportElement x="400" y="55" width="382" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="10" isBold="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Grand Total : Rs. " + $P{grandTotal}.setScale(2, java.math.RoundingMode.HALF_UP).toPlainString()]]>
                </textFieldExpression>
            </textField>

        </band>
    </title>

    <!-- COLUMN HEADER BAND -->
    <columnHeader>
        <band height="30">

            <!-- Sr No -->
            <staticText>
                <reportElement x="0" y="0" width="40" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Sr No]]></text>
            </staticText>

            <!-- Batch ID -->
            <staticText>
                <reportElement x="40" y="0" width="155" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Batch ID]]></text>
            </staticText>

            <!-- Cheque Count -->
            <staticText>
                <reportElement x="195" y="0" width="80" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Cheques]]></text>
            </staticText>

            <!-- Maker Name -->
            <staticText>
                <reportElement x="275" y="0" width="150" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Maker]]></text>
            </staticText>

            <!-- Actual Amount -->
            <staticText>
                <reportElement x="425" y="0" width="130" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Actual Amount (Rs.)]]></text>
            </staticText>

            <!-- Verified At -->
            <staticText>
                <reportElement x="555" y="0" width="127" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Verified At]]></text>
            </staticText>

            <!-- Status -->
            <staticText>
                <reportElement x="682" y="0" width="100" height="30"
                               backcolor="#2C3E50" forecolor="#FFFFFF" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Status]]></text>
            </staticText>

        </band>
    </columnHeader>

    <!-- DETAIL BAND — one row per verified batch -->
    <detail>
        <band height="25">

            <!-- Sr No -->
            <textField>
                <reportElement x="0" y="0" width="40" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{serialNo}]]>
                </textFieldExpression>
            </textField>

            <!-- Batch ID -->
            <textField>
                <reportElement x="40" y="0" width="155" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{batchId}]]>
                </textFieldExpression>
            </textField>

            <!-- Cheque Count -->
            <textField>
                <reportElement x="195" y="0" width="80" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{chequeCount}]]>
                </textFieldExpression>
            </textField>

            <!-- Maker Name -->
            <textField>
                <reportElement x="275" y="0" width="150" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{makerName}]]>
                </textFieldExpression>
            </textField>

            <!-- Actual Amount -->
            <textField>
                <reportElement x="425" y="0" width="130" height="25"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Rs. " + $F{actualAmount}.setScale(2, java.math.RoundingMode.HALF_UP).toPlainString()]]>
                </textFieldExpression>
            </textField>

            <!-- Verified At -->
            <textField>
                <reportElement x="555" y="0" width="127" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{verifiedAt}]]>
                </textFieldExpression>
            </textField>

            <!-- Status -->
            <textField>
                <reportElement x="682" y="0" width="100" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="9"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{status}]]>
                </textFieldExpression>
            </textField>

            <!-- Row separator line -->
            <line>
                <reportElement x="0" y="24" width="782" height="1"
                               forecolor="#CCCCCC"/>
            </line>

        </band>
    </detail>

    <!-- PAGE FOOTER -->
    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="782" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Page " + $V{PAGE_NUMBER}]]>
                </textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
